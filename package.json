{
  "name": "@kolsetu-opensource/elba-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for Elba — manage voice AI agents from any AI coding assistant",
  "type": "module",
  "bin": {
    "elba-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ __tests__/",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "release": "npm run build && changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Novathes/elba-mcp-server.git"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "voice-ai",
    "elba",
    "ai-agents"
  ],
  "author": "Kolsetu GmbH",
  "homepage": "https://github.com/Novathes/elba-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/Novathes/elba-mcp-server/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
