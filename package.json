{
  "name": "@kolsetu-opensource/elba-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for Elba — manage voice AI agents from any AI coding assistant",
  "type": "module",
  "bin": {
    "elba-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ __tests__/",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "release": "npm run build && changeset publish",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kolsetu-Opensource/elba-mcp-server.git"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "voice-ai",
    "elba",
    "ai-agents",
    "claude",
    "cursor",
    "vscode",
    "conversational-ai",
    "voice-agents",
    "ai-tools",
    "llm-tools"
  ],
  "author": "Kolsetu GmbH",
  "homepage": "https://github.com/Kolsetu-Opensource/elba-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/Kolsetu-Opensource/elba-mcp-server/issues"
  },
  "license": "MIT",
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
